# Example environment variables
# Copy this file to .env.local and fill in actual values

# Site configuration
NEXT_PUBLIC_SITE_URL=https://yoursite.com

# Analytics (when implemented)
NEXT_PUBLIC_GA_ID=

# Contact email delivery (required for /api/contact)
CONTACT_TO_EMAIL=info@meridianso.com
CONTACT_FROM_EMAIL=no-reply@meridianso.com
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Contact form rate limit
RATE_LIMIT_REQUESTS_PER_HOUR=20

# Error tracking (when implemented)
SENTRY_DSN=
